{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global Settings",
    "description": "Site-wide settings: navigation, footer, contact info, SEO defaults"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteTagline": {
      "type": "string"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "googleAnalyticsId": {
      "type": "string"
    },
    "facebookPixelId": {
      "type": "string"
    },
    "headerNavigation": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.nav-item"
    },
    "footerNavigation": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.nav-item"
    },
    "footerTagline": {
      "type": "text"
    },
    "copyrightText": {
      "type": "string"
    },
    "announcementBar": {
      "type": "string",
      "description": "Optional site-wide announcement banner text"
    },
    "announcementBarEnabled": {
      "type": "boolean",
      "default": false
    }
  }
}
