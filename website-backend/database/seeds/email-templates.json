{
    "emailTemplates": [
        {
            "name": "New Blog Post Notification",
            "slug": "new-post",
            "subject": "New Post: {{postTitle}}",
            "htmlBody": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>New Blog Post</title>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }\n    .post-image { width: 100%; max-width: 500px; height: auto; border-radius: 8px; margin: 20px 0; }\n    .post-title { font-size: 24px; color: #333; margin: 20px 0 10px; }\n    .post-excerpt { color: #666; margin: 10px 0 20px; }\n    .cta-button { display: inline-block; background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }\n    .unsubscribe { color: #999; font-size: 11px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Dr. Obinna Awiaka</h1>\n    <p>New Blog Post Published</p>\n  </div>\n  <div class=\"content\">\n    <p>Hello {{subscriberName}},</p>\n    <p>We've just published a new blog post that we think you'll enjoy!</p>\n    {{#if postImage}}\n    <img src=\"{{postImage}}\" alt=\"{{postTitle}}\" class=\"post-image\">\n    {{/if}}\n    <h2 class=\"post-title\">{{postTitle}}</h2>\n    <p class=\"post-excerpt\">{{postExcerpt}}</p>\n    <a href=\"{{postUrl}}\" class=\"cta-button\">Read Full Article</a>\n    <p>Published by {{authorName}} on {{publishedDate}}</p>\n  </div>\n  <div class=\"footer\">\n    <p>You're receiving this email because you subscribed to our newsletter.</p>\n    <p class=\"unsubscribe\"><a href=\"{{unsubscribeUrl}}\">Unsubscribe</a></p>\n  </div>\n</body>\n</html>",
            "textBody": "Hello {{subscriberName}},\n\nWe've just published a new blog post: {{postTitle}}\n\n{{postExcerpt}}\n\nRead the full article: {{postUrl}}\n\nPublished by {{authorName}} on {{publishedDate}}\n\n---\nYou're receiving this email because you subscribed to our newsletter.\nTo unsubscribe, visit: {{unsubscribeUrl}}",
            "templateType": "new-post",
            "variables": [
                "subscriberName",
                "postTitle",
                "postExcerpt",
                "postUrl",
                "postImage",
                "authorName",
                "publishedDate",
                "unsubscribeUrl"
            ],
            "isActive": true,
            "fromEmail": "noreply@drobinnaawiaka.com",
            "fromName": "Dr. Obinna Awiaka",
            "category": "notification",
            "priority": "normal",
            "description": "Sent to subscribers when a new blog post is published"
        },
        {
            "name": "New Service Notification",
            "slug": "new-service",
            "subject": "New Service: {{serviceName}}",
            "htmlBody": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>New Service</title>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }\n    .service-image { width: 100%; max-width: 500px; height: auto; border-radius: 8px; margin: 20px 0; }\n    .service-name { font-size: 24px; color: #333; margin: 20px 0 10px; }\n    .service-price { font-size: 20px; color: #667eea; font-weight: bold; margin: 10px 0; }\n    .service-description { color: #666; margin: 10px 0 20px; }\n    .cta-button { display: inline-block; background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }\n    .unsubscribe { color: #999; font-size: 11px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Dr. Obinna Awiaka</h1>\n    <p>New Service Available</p>\n  </div>\n  <div class=\"content\">\n    <p>Hello {{subscriberName}},</p>\n    <p>We're excited to announce a new service!</p>\n    {{#if serviceImage}}\n    <img src=\"{{serviceImage}}\" alt=\"{{serviceName}}\" class=\"service-image\">\n    {{/if}}\n    <h2 class=\"service-name\">{{serviceName}}</h2>\n    <p class=\"service-price\">{{servicePrice}}</p>\n    <p class=\"service-description\">{{serviceDescription}}</p>\n    {{#if serviceCategory}}\n    <p><strong>Category:</strong> {{serviceCategory}}</p>\n    {{/if}}\n    <a href=\"{{serviceUrl}}\" class=\"cta-button\">Learn More</a>\n  </div>\n  <div class=\"footer\">\n    <p>You're receiving this email because you subscribed to our newsletter.</p>\n    <p class=\"unsubscribe\"><a href=\"{{unsubscribeUrl}}\">Unsubscribe</a></p>\n  </div>\n</body>\n</html>",
            "textBody": "Hello {{subscriberName}},\n\nWe're excited to announce a new service: {{serviceName}}\n\nPrice: {{servicePrice}}\n\n{{serviceDescription}}\n\n{{#if serviceCategory}}Category: {{serviceCategory}}{{/if}}\n\nLearn more: {{serviceUrl}}\n\n---\nYou're receiving this email because you subscribed to our newsletter.\nTo unsubscribe, visit: {{unsubscribeUrl}}",
            "templateType": "new-service",
            "variables": [
                "subscriberName",
                "serviceName",
                "servicePrice",
                "serviceDescription",
                "serviceUrl",
                "serviceImage",
                "serviceCategory",
                "unsubscribeUrl"
            ],
            "isActive": true,
            "fromEmail": "noreply@drobinnaawiaka.com",
            "fromName": "Dr. Obinna Awiaka",
            "category": "notification",
            "priority": "normal",
            "description": "Sent to subscribers when a new service is added"
        },
        {
            "name": "Welcome Email",
            "slug": "welcome",
            "subject": "Welcome to Dr. Obinna Awiaka's Newsletter!",
            "htmlBody": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Welcome</title>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }\n    .welcome-message { font-size: 18px; color: #333; margin: 20px 0; }\n    .benefits { background: white; padding: 20px; border-radius: 8px; margin: 20px 0; }\n    .benefit-item { margin: 10px 0; padding-left: 20px; position: relative; }\n    .benefit-item:before { content: \"✓\"; position: absolute; left: 0; color: #667eea; }\n    .cta-button { display: inline-block; background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }\n    .unsubscribe { color: #999; font-size: 11px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Welcome to Dr. Obinna Awiaka!</h1>\n    <p>Thank you for subscribing</p>\n  </div>\n  <div class=\"content\">\n    <p class=\"welcome-message\">Hello {{subscriberName}},</p>\n    <p>Thank you for subscribing to our newsletter! We're thrilled to have you on board.</p>\n    <div class=\"benefits\">\n      <h3>What to expect:</h3>\n      <div class=\"benefit-item\">Latest blog posts and articles</div>\n      <div class=\"benefit-item\">New service announcements</div>\n      <div class=\"benefit-item\">Exclusive tips and insights</div>\n      <div class=\"benefit-item\">Special offers and promotions</div>\n    </div>\n    <a href=\"{{websiteUrl}}\" class=\"cta-button\">Visit Our Website</a>\n    <p>We promise to only send you valuable content and never spam your inbox.</p>\n  </div>\n  <div class=\"footer\">\n    <p>You're receiving this email because you subscribed to our newsletter.</p>\n    <p class=\"unsubscribe\"><a href=\"{{unsubscribeUrl}}\">Unsubscribe</a></p>\n  </div>\n</body>\n</html>",
            "textBody": "Hello {{subscriberName}},\n\nThank you for subscribing to our newsletter! We're thrilled to have you on board.\n\nWhat to expect:\n- Latest blog posts and articles\n- New service announcements\n- Exclusive tips and insights\n- Special offers and promotions\n\nVisit our website: {{websiteUrl}}\n\nWe promise to only send you valuable content and never spam your inbox.\n\n---\nYou're receiving this email because you subscribed to our newsletter.\nTo unsubscribe, visit: {{unsubscribeUrl}}",
            "templateType": "welcome",
            "variables": [
                "subscriberName",
                "websiteUrl",
                "unsubscribeUrl"
            ],
            "isActive": true,
            "fromEmail": "noreply@drobinnaawiaka.com",
            "fromName": "Dr. Obinna Awiaka",
            "category": "notification",
            "priority": "normal",
            "description": "Sent to new subscribers when they sign up"
        },
        {
            "name": "Booking Confirmation",
            "slug": "booking-confirmation",
            "subject": "Booking Confirmed - {{bookingReference}}",
            "htmlBody": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Booking Confirmed</title>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }\n    .booking-details { background: white; padding: 20px; border-radius: 8px; margin: 20px 0; }\n    .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; }\n    .detail-label { font-weight: bold; color: #666; }\n    .detail-value { color: #333; }\n    .cta-button { display: inline-block; background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Booking Confirmed!</h1>\n    <p>Thank you for your booking</p>\n  </div>\n  <div class=\"content\">\n    <p>Hello {{customerName}},</p>\n    <p>Your booking has been confirmed. Here are the details:</p>\n    <div class=\"booking-details\">\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Reference:</span>\n        <span class=\"detail-value\">{{bookingReference}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Service:</span>\n        <span class=\"detail-value\">{{serviceName}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Date:</span>\n        <span class=\"detail-value\">{{bookingDate}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Time:</span>\n        <span class=\"detail-value\">{{bookingTime}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Amount:</span>\n        <span class=\"detail-value\">{{bookingAmount}}</span>\n      </div>\n    </div>\n    <a href=\"{{bookingUrl}}\" class=\"cta-button\">View Booking Details</a>\n    <p>If you need to make any changes, please contact us as soon as possible.</p>\n  </div>\n  <div class=\"footer\">\n    <p>Thank you for choosing Dr. Obinna Awiaka!</p>\n  </div>\n</body>\n</html>",
            "textBody": "Hello {{customerName}},\n\nYour booking has been confirmed!\n\nBooking Details:\nReference: {{bookingReference}}\nService: {{serviceName}}\nDate: {{bookingDate}}\nTime: {{bookingTime}}\nAmount: {{bookingAmount}}\n\nView booking details: {{bookingUrl}}\n\nIf you need to make any changes, please contact us as soon as possible.\n\nThank you for choosing Dr. Obinna Awiaka!",
            "templateType": "booking-confirmation",
            "variables": [
                "customerName",
                "bookingReference",
                "serviceName",
                "bookingDate",
                "bookingTime",
                "bookingAmount",
                "bookingUrl"
            ],
            "isActive": true,
            "fromEmail": "noreply@drobinnaawiaka.com",
            "fromName": "Dr. Obinna Awiaka",
            "category": "transactional",
            "priority": "high",
            "description": "Sent when a booking is confirmed"
        },
        {
            "name": "Order Confirmation",
            "slug": "order-confirmation",
            "subject": "Order Confirmed - {{orderNumber}}",
            "htmlBody": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Order Confirmed</title>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }\n    .order-details { background: white; padding: 20px; border-radius: 8px; margin: 20px 0; }\n    .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; }\n    .detail-label { font-weight: bold; color: #666; }\n    .detail-value { color: #333; }\n    .cta-button { display: inline-block; background: #667eea; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px; margin: 20px 0; }\n    .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <h1>Order Confirmed!</h1>\n    <p>Thank you for your order</p>\n  </div>\n  <div class=\"content\">\n    <p>Hello {{customerName}},</p>\n    <p>Your order has been confirmed and is being processed. Here are the details:</p>\n    <div class=\"order-details\">\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Order Number:</span>\n        <span class=\"detail-value\">{{orderNumber}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Order Date:</span>\n        <span class=\"detail-value\">{{orderDate}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Total Amount:</span>\n        <span class=\"detail-value\">{{orderTotal}}</span>\n      </div>\n      <div class=\"detail-row\">\n        <span class=\"detail-label\">Payment Status:</span>\n        <span class=\"detail-value\">{{paymentStatus}}</span>\n      </div>\n    </div>\n    <a href=\"{{orderUrl}}\" class=\"cta-button\">View Order Details</a>\n    <p>We'll notify you when your order has been shipped.</p>\n  </div>\n  <div class=\"footer\">\n    <p>Thank you for shopping with Dr. Obinna Awiaka!</p>\n  </div>\n</body>\n</html>",
            "textBody": "Hello {{customerName}},\n\nYour order has been confirmed!\n\nOrder Details:\nOrder Number: {{orderNumber}}\nOrder Date: {{orderDate}}\nTotal Amount: {{orderTotal}}\nPayment Status: {{paymentStatus}}\n\nView order details: {{orderUrl}}\n\nWe'll notify you when your order has been shipped.\n\nThank you for shopping with Dr. Obinna Awiaka!",
            "templateType": "order-confirmation",
            "variables": [
                "customerName",
                "orderNumber",
                "orderDate",
                "orderTotal",
                "paymentStatus",
                "orderUrl"
            ],
            "isActive": true,
            "fromEmail": "noreply@drobinnaawiaka.com",
            "fromName": "Dr. Obinna Awiaka",
            "category": "transactional",
            "priority": "high",
            "description": "Sent when an order is confirmed"
        }
    ]
}